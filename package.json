{
  "name": "db",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "pages": "npx wrangler pages dev ./public",
    "deploy": "wrangler deploy",
    "pages-deploy": "npx wrangler pages deploy ./public --commit-dirty=true",
    "dev": "wrangler dev --port 8787",
    "start": "wrangler dev",
    "tail": "wrangler tail",
    "test": "vitest",
    "schema-local": "npx wrangler d1 execute souple --local --file ./schema.sql",
    "schema-global": "npx wrangler d1 execute souple --remote --file ./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "hono": "^4.12.27",
    "vitest": "~3.2.0"
  },
  "dependencies": {
    "wrangler": "^4.56.0"
  }
}
